Set-Content .gitignore @"
# Dependencies
node_modules/

# Build outputs
dist/
build/
.next/
out/

# Environment variables - NEVER commit these
.env
.env.local
.env.*.local

# Prisma
backend/prisma/dev.db
backend/prisma/*.db

# Logs
*.log
npm-debug.log*

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Testing
coverage/
"@

{backend